{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dialectic-guard.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-solo-implementation.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "comfyui-mcp": {
      "source": {
        "source": "github",
        "repo": "artokun/comfyui-mcp"
      }
    }
  },
  "enabledPlugins": {
    "comfy@comfyui-mcp": true
  }
}
